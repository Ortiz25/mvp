# ── CityNet Captive Portal — Pi-as-router edition ─────────────────────────
# Copy to backend/.env:  cp .env.example .env
# Then edit values below.

PORT=3000
NODE_ENV=production

# SQLite DB path (relative to backend/)
DB_PATH=./data/captive.db

# Media files directory
MEDIA_DIR=./media

# Admin panel token — change this to something random
ADMIN_TOKEN=change_me_to_something_random

# CORS — Pi LAN IP + hostname
CORS_ORIGINS=http://captive.local,http://192.168.100.1

# ── RADIUS / MySQL ────────────────────────────────────────────────────────
# FreeRADIUS + MariaDB run on the Pi itself.
RADIUS_DB_HOST=localhost
RADIUS_DB_USER=radius
RADIUS_DB_PASS=CHANGE_ME_radius_db_password
RADIUS_DB_PORT=3306

# ── iptables ──────────────────────────────────────────────────────────────
# LAN-facing interface (clients come in on this interface)
LAN_IFACE=eth1

# ── Network (for reference — not used by Node.js directly) ───────────────
# Pi LAN IP:  192.168.100.1
# DHCP pool:  192.168.100.50 – 192.168.100.200
# MikroTik management IP: 192.168.100.2 (dumb AP — no hotspot, no DHCP)
