# ── CityNet Captive Portal — Backend Environment ──────────────────────────
# Copy to backend/.env:  cp backend/.env.example backend/.env

PORT=3000
NODE_ENV=production
DB_PATH=./data/captive.db
MEDIA_DIR=./media

ADMIN_TOKEN=change_me_to_something_random
CORS_ORIGINS=http://captive.local

# ── MikroTik settings ─────────────────────────────────────────────────────
MIKROTIK_MOCK=false

# Router LAN IP
MIKROTIK_HOST=192.168.88.1

# Hotspot web port (for logout URL only)
MIKROTIK_HS_PORT=80

# RouterOS binary API port (confirmed open on your router)
MIKROTIK_API_PORT=8728

# API credentials — create in Winbox Terminal:
#   /user add name=pi-api password=CHANGE_ME group=full comment="Pi API"
MIKROTIK_API_USER=pi-api
MIKROTIK_API_PASS=CHANGE_ME

SUCCESS_REDIRECT=http://www.google.com
