# ── CityNet Captive Portal — RADIUS Edition ───────────────────────────────
# Copy to backend/.env:  cp backend/.env.example backend/.env

PORT=3000
NODE_ENV=production
DB_PATH=./data/captive.db
MEDIA_DIR=./media

ADMIN_TOKEN=change_me_to_something_random
CORS_ORIGINS=http://captive.local

# ── RADIUS / MySQL ────────────────────────────────────────────────────────
# FreeRADIUS runs on the Pi itself (localhost).
# Install:  sudo apt install freeradius freeradius-mysql mysql-server
# See RADIUS_SETUP.md for full configuration steps.

RADIUS_DB_HOST=localhost
RADIUS_DB_USER=radius
RADIUS_DB_PASS=CHANGE_ME_radius_db_password
RADIUS_DB_PORT=3306

# ── MikroTik ──────────────────────────────────────────────────────────────
# Only the LAN IP is needed — no API credentials required with RADIUS.
MIKROTIK_HOST=192.168.88.1
