# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────
# Absolute path on the Pi. setup.sh sets this automatically.
DB_PATH=/home/admin/apps/mvp/data/captive.db

# ── Media uploads ─────────────────────────────────────────────────────────
MEDIA_DIR=/home/admin/apps/mvp/media

# ── Admin token — CHANGE THIS before going live! ─────────────────────────
# Any secret string. Used in x-admin-token header by the admin dashboard.
ADMIN_TOKEN=CHANGE_ME_BEFORE_GOING_LIVE

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://captive.local,http://192.168.88.2

# ── MikroTik Hotspot ─────────────────────────────────────────────────────
#
# MIKROTIK_MOCK=true  → Dev / testing mode
#   - No router needed
#   - After portal flow, browser navigates to /success page (stays in SPA)
#   - Sessions are recorded in DB with mock hotspot grant
#   - Use this for: local dev, Pi testing without router, UAT demos
#
# MIKROTIK_MOCK=false → Live / production mode
#   - MikroTik Hotspot must be configured (see mikrotik/mikrotik-hotspot.rsc)
#   - After portal flow, browser is redirected to:
#       http://MIKROTIK_HOST/login?username=MAC&password=MAC&dst=original_url
#   - MikroTik authenticates and redirects to original destination
#   - User leaves captive.local — they go straight to the internet
#
MIKROTIK_MOCK=true
MIKROTIK_HOST=192.168.88.1
MIKROTIK_HS_PORT=80

# ── Fallback redirect (when MikroTik provides no ?dst=) ──────────────────
# Only used in mock mode. In live mode MikroTik always provides ?dst=.
SUCCESS_REDIRECT=http://www.google.com
