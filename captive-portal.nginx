# /etc/nginx/sites-available/captive-portal
# sudo cp captive-portal.nginx /etc/nginx/sites-available/captive-portal
# sudo ln -sf /etc/nginx/sites-available/captive-portal /etc/nginx/sites-enabled/captive-portal
# sudo rm -f /etc/nginx/sites-enabled/default
# sudo nginx -t && sudo systemctl reload nginx

# ── Captive Portal (port 80) ──────────────────────────────────────────────────
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;
    client_max_body_size 512M;

    # ── iOS / macOS — Apple CNA (Captive Network Assistant) ──────────────────
    # Apple probes these exact paths over HTTP after HTTPS fails (no cert).
    # Response must NOT be the "Success" body — anything else triggers popup.
    location = /hotspot-detect.html {
        return 302 http://captive.local/;
    }
    location = /success.txt {
        return 302 http://captive.local/;
    }
    location = /library/test/success.html {
        return 302 http://captive.local/;
    }
    # Apple also checks these on newer iOS versions
    location = /bag {
        return 302 http://captive.local/;
    }

    # ── Android / Chrome ──────────────────────────────────────────────────────
    # Android expects 204 No Content = internet OK, anything else = portal present
    location = /generate_204 {
        return 302 http://captive.local/;
    }
    location = /gen_204 {
        return 302 http://captive.local/;
    }

    # ── Windows NCSI (Network Connectivity Status Indicator) ─────────────────
    # Windows expects response body to be EXACTLY "Microsoft NCSI" (no newline)
    location = /ncsi.txt {
        return 200 "Microsoft NCSI";
        add_header Content-Type text/plain;
    }
    # Windows 10/11 also checks this path
    location = /connecttest.txt {
        return 200 "Microsoft NCSI";
        add_header Content-Type text/plain;
    }

    # ── Firefox ───────────────────────────────────────────────────────────────
    location = /canonical.html {
        return 302 http://captive.local/;
    }
    location = /redirect {
        return 302 http://captive.local/;
    }

    # ── API backend (portal + admin, video uploads) ───────────────────────────
    location /api/ {
        proxy_pass              http://127.0.0.1:3000;
        proxy_http_version      1.1;
        proxy_set_header        Host              $host;
        proxy_set_header        X-Real-IP         $remote_addr;
        proxy_set_header        X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_read_timeout      120s;
        proxy_send_timeout      120s;
        proxy_request_buffering off;
        client_max_body_size    512M;
    }

    # ── Video / media files ───────────────────────────────────────────────────
    location /media/ {
        proxy_pass          http://127.0.0.1:3000;
        proxy_set_header    X-Real-IP $remote_addr;
        add_header          Cache-Control "public, max-age=86400";
    }
    location /uploads/ {
        proxy_pass          http://127.0.0.1:3000;
        proxy_set_header    X-Real-IP $remote_addr;
        add_header          Cache-Control "public, max-age=86400";
    }

    # ── React SPA (captive portal frontend) ───────────────────────────────────
    location / {
        root      /home/admin/apps/mvp/frontend/dist;
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }
    location ~* \.(js|css|png|jpg|jpeg|gif|svg|woff2?|ico)$ {
        root      /home/admin/apps/mvp/frontend/dist;
        try_files $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }
}

# ── Admin Dashboard (port 8090 — LAN only) ────────────────────────────────────
server {
    listen 8090;
    server_name _;

    allow 192.168.88.0/24;
    allow 127.0.0.1;
    deny  all;

    client_max_body_size 512M;

    location /api/ {
        proxy_pass              http://127.0.0.1:3000;
        proxy_http_version      1.1;
        proxy_set_header        X-Real-IP $remote_addr;
        proxy_set_header        X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout      120s;
        proxy_send_timeout      120s;
        proxy_request_buffering off;
        client_max_body_size    512M;
    }
    location /media/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header X-Real-IP $remote_addr;
    }
    location /uploads/ {
        proxy_pass http://127.0.0.1:3000;
    }
    location / {
        root      /home/admin/apps/mvp/admin/dist;
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }
    location ~* \.(js|css|png|jpg|jpeg|gif|svg|woff2?|ico)$ {
        root      /home/admin/apps/mvp/admin/dist;
        try_files $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }
}

# ── Kolibri (walled garden — pre-auth access) ─────────────────────────────────
server {
    listen 80;
    server_name kolibri.local;

    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header   Host      $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_read_timeout 120s;
        client_max_body_size 100M;
    }
}
