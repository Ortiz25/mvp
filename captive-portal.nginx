# /etc/nginx/sites-available/captive-portal
#
# Install:
#   sudo cp captive-portal.nginx /etc/nginx/sites-available/captive-portal
#   sudo ln -sf /etc/nginx/sites-available/captive-portal /etc/nginx/sites-enabled/captive-portal
#   sudo rm -f /etc/nginx/sites-enabled/default
#   sudo nginx -t && sudo systemctl reload nginx

# ── Captive Portal — port 80 ──────────────────────────────────────────────
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name captive.local 192.168.88.2 _;

    client_max_body_size 512M;
    proxy_read_timeout   120s;

    # ── Captive portal OS detection endpoints ─────────────────────────────
    #
    # CRITICAL BEHAVIOUR CHANGE based on client auth state:
    #
    # PRE-AUTH (client not in hotspot active list):
    #   MikroTik intercepts the /generate_204 request at the network layer
    #   and redirects it to captive.local. So this nginx block handles it.
    #   We return 204 — the OS sees "internet works" and dismisses the
    #   captive portal WebView automatically. BUT MikroTik still blocks
    #   real traffic until the MAC is in /ip/hotspot/user.
    #   
    #   Wait — actually we want the OS to SHOW the captive portal WebView
    #   so the user can complete the video/survey flow. So for /generate_204
    #   we should return 200 (not 204) to make the OS keep the WebView open.
    #
    # POST-AUTH (MAC added to /ip/hotspot/user by our backend):
    #   MikroTik no longer intercepts — the request goes directly to google.
    #   Google returns 204 from connectivitycheck.gstatic.com/generate_204.
    #   OS detects internet and dismisses WebView. ✓
    #
    # SOLUTION: Return 200 (not 204) from our portal for connectivity checks.
    # This keeps the captive portal WebView open pre-auth.
    # Post-auth, the real internet serves 204 from google's servers directly.
    #
    location = /generate_204         { return 200; }
    location = /gen_204              { return 200; }

    # Windows NCSI — return proper response to keep "No internet" indicator
    # showing until real internet is available
    location = /connecttest.txt      {
        add_header Content-Type text/plain;
        return 200 "Microsoft NCSI";
    }
    location = /ncsi.txt             {
        add_header Content-Type text/plain;
        return 200 "Microsoft NCSI";
    }
    location = /canonical.html       { return 302 http://captive.local/; }
    location = /success.txt          {
        add_header Content-Type text/plain;
        return 200 "success";
    }
    location = /hotspot-detect.html  { return 302 http://captive.local/; }
    location /library/test/success.html {
        add_header Content-Type text/html;
        return 200 "<HTML><HEAD><TITLE>Success</TITLE></HEAD><BODY>Success</BODY></HTML>";
    }

    # ── Node.js API ───────────────────────────────────────────────────────
    location /api/ {
        proxy_pass             http://127.0.0.1:3000;
        proxy_http_version     1.1;
        proxy_set_header       Host              $host;
        proxy_set_header       X-Real-IP         $remote_addr;
        proxy_set_header       X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_read_timeout     120s;
        proxy_request_buffering off;
    }

    # ── Media files ───────────────────────────────────────────────────────
    location /media/ {
        proxy_pass        http://127.0.0.1:3000;
        proxy_set_header  X-Real-IP $remote_addr;
        add_header        Cache-Control "public, max-age=86400";
    }
    location /uploads/ {
        proxy_pass        http://127.0.0.1:3000;
        proxy_set_header  X-Real-IP $remote_addr;
        add_header        Cache-Control "public, max-age=86400";
    }

    # ── Fingerprinted static assets ───────────────────────────────────────
    location ~* \.(js|css|woff2?|png|jpg|svg|ico)$ {
        root       /home/admin/apps/mvp/frontend/dist;
        try_files  $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }

    # ── React SPA ─────────────────────────────────────────────────────────
    location / {
        root       /home/admin/apps/mvp/frontend/dist;
        try_files  $uri $uri/ /index.html;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma        "no-cache";
        add_header Expires       "0";
    }
}

# ── Admin Dashboard — port 8090 ───────────────────────────────────────────
server {
    listen 8090;
    server_name _;

    allow 127.0.0.1;
    allow 192.168.88.0/24;
    allow 192.168.1.0/24;
    allow 192.168.8.0/24;
    deny  all;

    client_max_body_size 512M;

    location /api/ {
        proxy_pass             http://127.0.0.1:3000;
        proxy_http_version     1.1;
        proxy_set_header       X-Real-IP $remote_addr;
        proxy_read_timeout     120s;
        proxy_request_buffering off;
    }

    location /media/   { proxy_pass http://127.0.0.1:3000; }
    location /uploads/ { proxy_pass http://127.0.0.1:3000; }

    location ~* \.(js|css|woff2?|png|jpg|svg|ico)$ {
        root       /home/admin/apps/mvp/admin/dist;
        try_files  $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }

    location / {
        root      /home/admin/apps/mvp/admin/dist;
        try_files $uri $uri/ /index.html;
    }
}

# ── Kolibri ───────────────────────────────────────────────────────────────
server {
    listen 80;
    server_name kolibri.local;

    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header   Host      $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_read_timeout 120s;
        client_max_body_size 100M;
    }
}
