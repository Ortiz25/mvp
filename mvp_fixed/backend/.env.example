# ── CityNet Captive Portal — Backend Environment ──────────────────────────
# Copy to backend/.env and fill in values before starting on the Pi.

PORT=3000
NODE_ENV=production
DB_PATH=./data/captive.db
MEDIA_DIR=./media

# Admin dashboard auth token — change this to something random
ADMIN_TOKEN=change_me_to_something_random

# CORS — allow the frontend served by nginx on the Pi
CORS_ORIGINS=http://captive.local

# ── MikroTik Hotspot settings ─────────────────────────────────────────────
#
# MIKROTIK_MOCK=false  →  LIVE mode (use on the Pi)
# MIKROTIK_MOCK=true   →  MOCK mode (use for local dev, no router needed)
#
MIKROTIK_MOCK=false

# IP of the MikroTik router (default gateway on the hotspot network)
MIKROTIK_HOST=192.168.88.1

# MikroTik Hotspot HTTP port (default 80)
MIKROTIK_HS_PORT=80

# Where to send users after grant when no real dst URL was captured
# (happens when the portal is triggered by a captive portal probe like /generate_204)
SUCCESS_REDIRECT=http://www.google.com
